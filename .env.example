# Discord OAuth2
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/poker/api/auth/callback
REQUIRED_GUILD_ID=your_discord_server_id
REQUIRED_ROLE_ID=your_required_role_id
DISCORD_BOT_TOKEN=your_discord_bot_token

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Frontend URL for OAuth redirect
# dev root: http://localhost:5173
# dev with /poker prefix: http://localhost:5173/poker
# production same-origin /poker: leave empty
FRONTEND_URL=http://localhost:5173/poker

# Admin (Discord user IDs that can manage the tournament, comma-separated)
ADMIN_USER_IDS=your_discord_user_id

# Optional: override tournament config path
# CONFIG_DIR=./configs
# TOURNAMENT_CONFIG_FILE=tournament.yaml
